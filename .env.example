SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SESSION_SECRET=replace-me-with-strong-random-string
ADMIN_PASSPHRASE=replace-me-admin-passphrase
PORT=8080

# ─── Admin accounts ─────────────────────────────────────────────────────────
# tom@alamut-im.com is hard-wired as the primary superuser/admin.
# Configure the second admin via SECOND_ADMIN_EMAIL (or the comma-separated
# ADMIN_EMAILS list — primary is always added automatically).
SECOND_ADMIN_EMAIL=
# ADMIN_EMAILS=tom@alamut-im.com,second-admin@alamut-im.com

# ─── Dev-only passwords (never set these in production) ─────────────────────
# Used by the in-memory seed fallback when Supabase is not configured.
# Production deployments store bcrypt hashes in `team_members.password_hash`.
ADMIN_DEV_PASSWORD=
TEAM_DEV_PASSWORD=
