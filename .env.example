SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SESSION_SECRET=replace-me-with-strong-random-string
ADMIN_PASSPHRASE=replace-me-admin-passphrase
PORT=8080

# ─── Admin accounts ─────────────────────────────────────────────────────────
# Two senior personnel hold admin rights:
#   • tom@alamut-im.com    — primary superuser/admin (hard-wired)
#   • alice@alamut-im.com  — second admin (default; override via the env
#                            vars below if a different email is needed)
SECOND_ADMIN_EMAIL=
# ADMIN_EMAILS=tom@alamut-im.com,alice@alamut-im.com

# ─── Dev-only passwords (never set these in production) ─────────────────────
# Used by the in-memory seed fallback when Supabase is not configured.
# Production deployments store bcrypt hashes in `team_members.password_hash`.
ADMIN_DEV_PASSWORD=
TEAM_DEV_PASSWORD=
