# Always install devDependencies, even when NODE_ENV=production is set during
# the Railway build phase. Vite, esbuild, tsx, and TypeScript live in
# devDependencies and are required to produce dist/index.cjs and dist/public/.
# After the build phase the bundled output no longer needs them at runtime.
include=dev

# Quiet noisy network calls that don't affect the build outcome.
audit=false
fund=false
